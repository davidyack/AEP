{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aep.dev/schemas/scenario.schema.json",
  "title": "Scenario",
  "description": "Executable test case. Linear message lists are supported as a degenerate case; branching and state are first-class.",
  "type": "object",
  "required": ["scenarioId", "title", "category", "turns"],
  "properties": {
    "scenarioId": {"type": "string"},
    "title": {"type": "string"},
    "category": {"enum": ["quality", "safety", "security", "rai", "performance", "regression", "red-team"]},
    "description": {"type": "string"},
    "persona": {
      "type": "object",
      "properties": {
        "role": {"type": "string", "description": "E.g. 'novice user', 'adversarial researcher', 'benign power user'."},
        "background": {"type": "string"},
        "goals": {"type": "array", "items": {"type": "string"}}
      }
    },
    "preconditions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "What must be true for this scenario to be valid. E.g. 'agent is configured with tool X'."
    },
    "turns": {
      "type": "array",
      "items": {"$ref": "#/$defs/Turn"},
      "description": "Ordered turns. A linear scenario has exactly one branch per turn; a branching scenario uses 'branches' to select next turn based on output."
    },
    "expectedBehavior": {
      "type": "array",
      "items": {"type": "string"},
      "description": "High-level expectations. Used by LLM-as-judge scoring."
    },
    "failureConditions": {
      "type": "array",
      "items": {"$ref": "#/$defs/FailureCondition"},
      "description": "Conditions that, if triggered at any turn, halt the scenario and emit a finding."
    },
    "scoring": {
      "type": "object",
      "description": "Scoring configuration. Multiple methods may be attached. See ../docs/SCORING.md.",
      "properties": {
        "deterministic": {"type": "array", "items": {"type": "object"}},
        "llmAsJudge": {"type": "object"},
        "human": {"type": "object"},
        "regression": {"type": "object"}
      }
    },
    "timeoutSeconds": {"type": "integer", "minimum": 1},
    "tags": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "Turn": {
      "type": "object",
      "required": ["turnId", "input"],
      "properties": {
        "turnId": {"type": "string"},
        "input": {
          "oneOf": [
            {"type": "string", "description": "Literal input text."},
            {
              "type": "object",
              "required": ["template"],
              "properties": {
                "template": {"type": "string"},
                "variables": {"type": "object", "additionalProperties": true}
              },
              "description": "Templated input with variable substitution."
            },
            {
              "type": "object",
              "required": ["adaptive"],
              "properties": {
                "adaptive": {
                  "type": "string",
                  "description": "Attacker-model prompt. The actual input is generated by an adversarial model given prior turns. Used for adaptive red-team scenarios."
                }
              }
            }
          ]
        },
        "assertions": {
          "type": "array",
          "items": {"$ref": "#/$defs/Assertion"},
          "description": "Assertions to evaluate against this turn's output."
        },
        "branches": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["when", "nextTurnId"],
            "properties": {
              "when": {"type": "string", "description": "Condition on this turn's output. E.g. 'output contains refusal'."},
              "nextTurnId": {"type": "string"}
            }
          },
          "description": "Conditional next-turn selection. If omitted, proceeds to the next turn in order."
        },
        "stateUpdates": {
          "type": "object",
          "description": "Variables to update based on this turn's output, available to subsequent turns."
        }
      }
    },
    "Assertion": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {"enum": ["contains", "not-contains", "matches-regex", "is-refusal", "invokes-tool", "does-not-invoke-tool", "triggers-policy", "does-not-trigger-policy", "judge"]},
        "value": {"description": "Type-specific value."},
        "severity": {"enum": ["low", "medium", "high", "critical"]},
        "message": {"type": "string", "description": "Finding message if assertion fails."}
      }
    },
    "FailureCondition": {
      "type": "object",
      "required": ["when", "severity"],
      "properties": {
        "when": {"type": "string"},
        "severity": {"enum": ["low", "medium", "high", "critical"]},
        "haltScenario": {"type": "boolean", "default": false}
      }
    }
  },
  "additionalProperties": false
}

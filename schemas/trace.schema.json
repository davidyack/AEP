{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aep.dev/schemas/trace.schema.json",
  "title": "Trace",
  "description": "Canonical record of an AEP session's execution, including reasoning steps, tool usage, decision paths, and model calls. AEP-compliant servers MUST produce a Trace for every session, sealed after completion. Traces MUST be sufficient for deterministic replay when the agent declares 'replaySupported: true'.",
  "type": "object",
  "required": [
    "traceId",
    "sessionId",
    "aepVersion",
    "testMode",
    "injectedContext",
    "turns",
    "finalOutcome",
    "sealed",
    "startedAt"
  ],
  "properties": {
    "traceId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{22,128}$",
      "description": "Opaque high-entropy trace reference (AEP-REQ-126). Implementations MUST ensure at least 128 bits of unpredictability regardless of textual length."
    },
    "sessionId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{22,128}$",
      "description": "Opaque high-entropy session reference (AEP-REQ-126). Implementations MUST ensure at least 128 bits of unpredictability regardless of textual length."
    },
    "aepVersion": {"type": "string"},
    "agentId": {
      "type": "string",
      "description": "Required for single-agent sessions. OPTIONAL for composite sessions (§11.7 CSE extension); in that case per-turn nodeId identifies the active agent."
    },
    "agentVersion": {
      "type": "string",
      "description": "Required when agentId is set."
    },
    "testMode": {
      "enum": ["blackbox", "graybox", "policybox", "toolbox", "sandboxed-live", "replay"],
      "description": "Mode in which this trace was captured. Replay access MUST honor this mode — a trace captured in 'toolbox' MUST NOT be replayed by a caller authorized only for 'blackbox'."
    },
    "sealed": {
      "type": "boolean",
      "description": "Once true, the trace is immutable. Servers MUST reject any mutation attempts."
    },
    "sealedAt": {"type": "string", "format": "date-time"},
    "canonicalSerialization": {
      "type": "string",
      "description": "Canonical serialization method used for signing (AEP-REQ-124). v0.1 allows JCS-RFC8785; future versions may add values.",
      "enum": ["JCS-RFC8785"]
    },
    "canonicalDigest": {
      "type": "string",
      "pattern": "^(sha256:[A-Fa-f0-9]{64}|sha384:[A-Fa-f0-9]{96}|sha512:[A-Fa-f0-9]{128})$",
      "description": "Digest over canonical serialized bytes (AEP-REQ-124)."
    },
    "signature": {
      "$ref": "#/$defs/SignatureEnvelope",
      "description": "Signature over canonicalDigest with key identifier kid (AEP-REQ-124)."
    },
    "startedAt": {"type": "string", "format": "date-time"},
    "completedAt": {"type": "string", "format": "date-time"},
    "injectedContext": {
      "type": "object",
      "description": "Snapshot of context injected at session creation. Required for deterministic replay."
    },
    "seed": {
      "type": "string",
      "description": "Random seed used, when the agent declares 'seeded' determinism."
    },
    "turns": {
      "type": "array",
      "items": {"$ref": "#/$defs/TraceTurn"}
    },
    "finalOutcome": {
      "$ref": "#/$defs/FinalOutcome",
      "description": "Canonical completion record for the session. Required even for failed and aborted sessions."
    },
    "sensitivity": {
      "$ref": "#/$defs/SensitivityLabel",
      "description": "Overall trace sensitivity classification (AEP-REQ-127)."
    },
    "redactions": {
      "type": "array",
      "items": {"$ref": "#/$defs/RedactionRecord"},
      "description": "Explicit redaction records for sensitive content removed from this trace (AEP-REQ-127)."
    },
    "decisionPath": {
      "type": "array",
      "items": {"$ref": "#/$defs/DecisionNode"},
      "description": "Optional higher-level record of agent decisions (e.g. for agents with explicit planners or router models)."
    },
    "errors": {
      "type": "array",
      "items": {"$ref": "#/$defs/TraceError"}
    },
    "replay": {
      "$ref": "#/$defs/ReplayMetadata"
    }
  },
  "$defs": {
    "TraceTurn": {
      "type": "object",
      "required": ["turnIndex", "input", "output", "inputDigest", "outputDigest", "startedAt", "completedAt"],
      "properties": {
        "turnIndex": {"type": "integer", "minimum": 0},
        "turnId": {"type": "string"},
        "nodeId": {
          "type": "string",
          "description": "Optional (§11.7 CSE extension). When present, identifies which graph node was the active agent for this turn. Absent for single-agent sessions."
        },
        "input": {"description": "Input as submitted. May be object or string depending on agent inputSchema."},
        "output": {"description": "Output as returned. May be object or string depending on agent outputSchema."},
        "inputDigest": {"type": "string", "description": "Hash of normalized input. Required for replay verification."},
        "outputDigest": {"type": "string"},
        "startedAt": {"type": "string", "format": "date-time"},
        "completedAt": {"type": "string", "format": "date-time"},
        "latencyMs": {"type": "integer"},
        "reasoning": {
          "type": "array",
          "items": {"$ref": "#/$defs/ReasoningStep"},
          "description": "Reasoning steps exposed per the agent's traceabilityContract.reasoning level."
        },
        "toolCalls": {
          "type": "array",
          "items": {"$ref": "#/$defs/ToolCallEvent"}
        },
        "policyEvents": {
          "type": "array",
          "items": {"$ref": "#/$defs/PolicyEvent"}
        },
        "modelCalls": {
          "type": "array",
          "items": {"$ref": "#/$defs/ModelCallRecord"}
        },
        "stateSnapshot": {
          "type": "object",
          "description": "Captured agent state after this turn. Required for deterministic replay of multi-turn sessions."
        },
        "inputSensitivity": {
          "$ref": "#/$defs/SensitivityLabel"
        },
        "outputSensitivity": {
          "$ref": "#/$defs/SensitivityLabel"
        }
      }
    },
    "FinalOutcome": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "enum": ["completed", "failed", "timed_out", "aborted"]
        },
        "summary": {"type": "string"},
        "errorRef": {"type": "string", "description": "Optional pointer to a trace error record explaining the terminal failure."}
      }
    },
    "ReasoningStep": {
      "type": "object",
      "required": ["stepId", "type"],
      "properties": {
        "stepId": {"type": "string"},
        "type": {"enum": ["plan", "decide", "retrieve", "evaluate", "reflect", "other"]},
        "summary": {"type": "string", "description": "Short description suitable for 'summary' reasoning level."},
        "detail": {"type": "string", "description": "Full content suitable for 'step-by-step' or 'full' reasoning level."},
        "timestamp": {"type": "string", "format": "date-time"}
      }
    },
    "ToolCallEvent": {
      "type": "object",
      "required": ["toolCallId", "toolName", "startedAt"],
      "properties": {
        "toolCallId": {"type": "string"},
        "toolName": {"type": "string"},
        "arguments": {"description": "Arguments passed to the tool."},
        "result": {"description": "Tool return value."},
        "error": {"type": "string"},
        "sandboxed": {"type": "boolean"},
        "sandboxFidelity": {"enum": ["none", "stub", "recorded", "simulated", "real-isolated"]},
        "startedAt": {"type": "string", "format": "date-time"},
        "completedAt": {"type": "string", "format": "date-time"},
        "latencyMs": {"type": "integer"}
      }
    },
    "PolicyEvent": {
      "type": "object",
      "required": ["policyEventId", "ruleId", "outcome", "timestamp"],
      "properties": {
        "policyEventId": {"type": "string"},
        "ruleId": {"type": "string"},
        "outcome": {"enum": ["passed", "warned", "refused", "redacted", "escalated", "logged"]},
        "matchedCondition": {"type": "string"},
        "actionTaken": {"type": "string"},
        "severity": {"enum": ["low", "medium", "high", "critical"]},
        "timestamp": {"type": "string", "format": "date-time"}
      }
    },
    "ModelCallRecord": {
      "type": "object",
      "required": ["modelCallId", "model"],
      "properties": {
        "modelCallId": {"type": "string"},
        "model": {"type": "string"},
        "promptDigest": {"type": "string"},
        "prompt": {"type": "string", "description": "Full prompt text. Present only when traceabilityContract.modelCalls is 'full'."},
        "responseDigest": {"type": "string"},
        "response": {"type": "string"},
        "inputTokens": {"type": "integer"},
        "outputTokens": {"type": "integer"},
        "latencyMs": {"type": "integer"},
        "parameters": {
          "type": "object",
          "description": "Model parameters (temperature, top_p, etc.). Required for deterministic replay.",
          "additionalProperties": true
        }
      }
    },
    "DecisionNode": {
      "type": "object",
      "required": ["nodeId", "type"],
      "properties": {
        "nodeId": {"type": "string"},
        "type": {"enum": ["route", "plan", "select-tool", "escalate", "refuse", "answer"]},
        "rationale": {"type": "string"},
        "alternatives": {"type": "array", "items": {"type": "string"}, "description": "Other options considered."},
        "timestamp": {"type": "string", "format": "date-time"}
      }
    },
    "TraceError": {
      "type": "object",
      "required": ["errorId", "code", "timestamp"],
      "properties": {
        "errorId": {"type": "string"},
        "code": {"type": "integer"},
        "message": {"type": "string"},
        "recoverable": {"type": "boolean"},
        "turnIndex": {"type": "integer"},
        "timestamp": {"type": "string", "format": "date-time"}
      }
    },
    "ReplayMetadata": {
      "type": "object",
      "properties": {
        "replayable": {"type": "boolean"},
        "protocolVersion": {"type": "string"},
        "completeness": {"enum": ["partial", "complete"]},
        "nondeterministicPoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "location": {"type": "string"},
              "reason": {"type": "string"}
            }
          }
        }
      }
    },
    "SignatureEnvelope": {
      "type": "object",
      "required": ["alg", "kid", "sig"],
      "properties": {
        "alg": {
          "type": "string",
          "enum": ["Ed25519", "ES256", "ES384"]
        },
        "kid": {
          "type": "string",
          "description": "Signing key identifier (AEP-REQ-124)."
        },
        "sig": {
          "type": "string",
          "description": "Base64url-encoded signature bytes."
        }
      },
      "additionalProperties": false
    },
    "SensitivityLabel": {
      "type": "object",
      "required": ["level"],
      "properties": {
        "level": {
          "enum": ["public", "internal", "confidential", "restricted"]
        },
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "RedactionRecord": {
      "type": "object",
      "required": ["path", "reason", "redactedAt"],
      "properties": {
        "path": {
          "type": "string",
          "description": "JSON pointer or trace path of the redacted field."
        },
        "reason": {
          "type": "string",
          "description": "Why redaction was applied."
        },
        "redactedAt": {
          "type": "string",
          "format": "date-time"
        },
        "originalDigest": {
          "type": "string",
          "pattern": "^(sha256:[A-Fa-f0-9]{64}|sha384:[A-Fa-f0-9]{96}|sha512:[A-Fa-f0-9]{128})$",
          "description": "Digest of original redacted payload when retained for audit."
        },
        "sensitivity": {
          "$ref": "#/$defs/SensitivityLabel"
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "sealed": {"const": true}
        }
      },
      "then": {
        "required": ["sealedAt", "canonicalSerialization", "canonicalDigest", "signature"]
      }
    }
  ],
  "additionalProperties": false
}
